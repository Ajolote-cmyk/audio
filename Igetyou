-- Función principal
local function processTool(targetTool)
    if not targetTool then return end
    
    local settingModule = targetTool:FindFirstChild("Setting")
    if not settingModule then return end
    
    -- Verificar si es un ModuleScript y cargarlo
    if settingModule:IsA("ModuleScript") then
        -- Guardar settings originales si es necesario
        if currentToolName ~= targetTool.Name or not originalSettings or next(originalSettings) == nil then
            currentToolName = targetTool.Name
            saveOriginalSettings(require(settingModule))
        end
        
        -- Limpiar el caché del require para forzar recarga
        local cacheKey = settingModule
        if getfenv then
            -- Intentar limpiar caché si existe
            pcall(function()
                package.loaded[cacheKey] = nil
            end)
        end
        
        -- Recargar el módulo
        local settings = require(settingModule)
        
        -- Aplicar según el modo
        if isModified then
            applyModifiedSettings(settings)
        else
            applyNormalSettings(settings)
        end
    end
end

local function applySettings(character)
    if not character then return end
    
    tool = character:FindFirstChildOfClass("Tool") or player.Backpack:FindFirstChildOfClass("Tool")
    
    if tool and tool:FindFirstChild("Setting") then
        processTool(tool)
    else
        print("⏳ Esperando arma...")
    end
end

-- Lógica del botón
toggleButton.MouseButton1Click:Connect(function()
    isModified = not isModified
    
    if isModified then
        toggleButton.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        toggleButton.Text = "MODO: MODIFICADO"
    else
        toggleButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        toggleButton.Text = "MODO: NORMAL"
    end
    
    -- Limpiar todo el caché de módulos
    pcall(function()
        for k, v in pairs(package.loaded) do
            if type(k) == "userdata" and k:IsA("ModuleScript") and k.Name == "Setting" then
                package.loaded[k] = nil
            end
        end
    end)
    
    if player.Character then
        applySettings(player.Character)
    end
end)

-- Eventos
if player.Character then
    applySettings(player.Character)
end

player.CharacterAdded:Connect(function(newCharacter)
    wait(0.5) 
    applySettings(newCharacter)
end)

player.Backpack.ChildAdded:Connect(function(child)
    if child:IsA("Tool") and child:FindFirstChild("Setting") then
        wait(0.2)
        applySettings(player.Character)
    end
end)

player.Backpack.ChildRemoved:Connect(function(child)
    if child:IsA("Tool") and child:FindFirstChild("Setting") then
        wait(0.2)
        applySettings(player.Character)
    end
end)