local player = game.Players.LocalPlayer
local tool = nil
local originalSettings = {}
local isModified = false
local currentToolName = nil

-- Crear el botón UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0, 200, 0, 50)
toggleButton.Position = UDim2.new(0.5, -100, 0, 10)
toggleButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleButton.Text = "MODO: NORMAL"
toggleButton.Font = Enum.Font.SourceSansBold
toggleButton.TextSize = 20
toggleButton.Parent = screenGui

-- Hacer el botón arrastrable
local dragging = false
local dragStart = nil
local startPos = nil

toggleButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = toggleButton.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

toggleButton.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        toggleButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Función para copiar una tabla (copia profunda simple)
local function deepCopy(original)
    local copy = {}
    for k, v in pairs(original) do
        if type(v) == "table" then
            copy[k] = deepCopy(v)
        else
            copy[k] = v
        end
    end
    return copy
end

-- Función para guardar las settings originales
local function saveOriginalSettings(settingModule)
    originalSettings = {}
    for k, v in pairs(settingModule) do
        if type(v) ~= "function" and type(v) ~= "userdata" then
            if type(v) == "table" then
                originalSettings[k] = deepCopy(v)
            else
                originalSettings[k] = v
            end
        end
    end
    print("💾 Settings originales guardadas: " .. currentToolName)
end

-- Función para aplicar settings normales
local function applyNormalSettings(settingModule)
    for k, v in pairs(originalSettings) do
        if settingModule[k] ~= nil then
            if type(v) == "table" then
                -- Para tablas, copiamos los valores individualmente
                for subK, subV in pairs(v) do
                    if type(settingModule[k]) == "table" then
                        settingModule[k][subK] = subV
                    end
                end
            else
                settingModule[k] = v
            end
        end
    end
    print("✅ Modo NORMAL activado")
end

